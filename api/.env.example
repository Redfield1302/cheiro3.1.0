# Use NODE_ENV=development para permitir seed automatica (se habilitada no server).
NODE_ENV=development
DATABASE_URL=postgresql://cheiro3:cheiro3@localhost:5432/cheiro3?schema=public

# ===============================
# CENARIO 2: PRODUCAO
# ===============================
# Para producao, troque apenas estes valores:
# NODE_ENV=production
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

JWT_SECRET=change-me
PORT=3000
MENU_BASE_URL=https://menu.seudominio.com
